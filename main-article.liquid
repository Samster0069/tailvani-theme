<article style="max-width:760px;margin:0 auto;padding:60px 40px 100px">
  <p style="font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#8C6E52;margin-bottom:14px">
    <a href="{{ blog.url }}" style="text-decoration:none;color:inherit">{{ blog.title }}</a> · {{ article.published_at | date: '%B %d, %Y' }}
  </p>
  <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(36px,4vw,54px);font-weight:300;color:#3D2B1F;line-height:1.1;margin-bottom:32px">{{ article.title }}</h1>
  {% if article.image %}
    <img src="{{ article.image | image_url: width: 900 }}" alt="{{ article.image.alt }}" width="900" height="506" style="width:100%;border-radius:3px;object-fit:cover;margin-bottom:40px"/>
  {% endif %}
  <div style="font-size:16px;line-height:1.85;color:#3D2B1F">{{ article.content }}</div>
  <div style="margin-top:60px;padding-top:40px;border-top:1px solid #E8DFD0">
    <a href="{{ blog.url }}" style="font-size:12px;letter-spacing:.1em;text-transform:uppercase;font-weight:500;color:#8C6E52;text-decoration:none;border-bottom:1px solid #C4B49A;padding-bottom:2px">← Back to {{ blog.title }}</a>
  </div>
</article>

{% schema %}
{
  "name": "Article",
  "settings": [],
  "presets": [{ "name": "Article" }]
}
{% endschema %}
