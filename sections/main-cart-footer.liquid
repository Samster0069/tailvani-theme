{% if cart.item_count > 0 %}
  <div style="max-width:1000px;margin:0 auto;padding:0 40px 80px">
    <div style="max-width:400px;margin-left:auto">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;padding:20px 0;border-top:1px solid #E8DFD0">
        <span style="font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:#8C6E52">Subtotal</span>
        <span style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:#3D2B1F">{{ cart.total_price | money }}</span>
      </div>
      <p style="font-size:12px;color:#C4B49A;margin-bottom:20px">Shipping and taxes calculated at checkout</p>
      <a href="{{ routes.checkout }}" style="display:block;width:100%;text-align:center;background:#3D2B1F;color:#F5F0E8;padding:18px;font-size:12px;letter-spacing:.12em;text-transform:uppercase;font-weight:500;border-radius:2px;text-decoration:none;transition:background .2s">Proceed to Checkout</a>
      <a href="/collections/all" style="display:block;text-align:center;margin-top:14px;font-size:13px;color:#8C6E52;text-decoration:underline;text-underline-offset:3px">Continue Shopping</a>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Cart Footer",
  "settings": [],
  "presets": [{ "name": "Cart Footer" }]
}
{% endschema %}
