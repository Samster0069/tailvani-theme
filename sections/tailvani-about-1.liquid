<section class="tv-about-hero">
  <div class="tv-about-hero__inner">
    <div>
      <div class="tv-eyebrow" style="color:var(--tv-taupe)">{{ section.settings.eyebrow }}</div>
      <h1 class="tv-about-hero__title">{{ section.settings.headline }}</h1>
      <p class="tv-about-hero__body">{{ section.settings.hero_body }}</p>
    </div>
    {% if section.settings.hero_image %}
      <div class="tv-about-hero__visual">
        <div class="tv-about-hero__img">
          <img src="{{ section.settings.hero_image | image_url: width: 900 }}" alt="Tailvani brand story" loading="eager" width="900" height="1125"/>
        </div>
        {% if section.settings.quote != blank %}
          <div class="tv-about-float">
            <p class="tv-about-float__quote">{{ section.settings.quote }}</p>
            <div class="tv-about-float__source">{{ section.settings.quote_source }}</div>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

<section class="tv-mission">
  <div class="tv-eyebrow">{{ section.settings.mission_eyebrow }}</div>
  <p class="tv-mission__quote">{{ section.settings.mission_quote }}</p>
  <div class="tv-mission__divider"></div>
  <p class="tv-mission__body">{{ section.settings.mission_body }}</p>
</section>

<section class="tv-values">
  <div class="tv-eyebrow">{{ section.settings.values_eyebrow }}</div>
  <h2 class="tv-section-title" style="margin-bottom:48px">{{ section.settings.values_title }}</h2>
  <div class="tv-values__grid">
    {% for block in section.blocks %}
      {% if block.type == 'value' %}
        <div class="tv-value-card tv-reveal">
          <div class="tv-value-card__num">0{{ forloop.index }}</div>
          <div class="tv-value-card__icon">{{ block.settings.icon }}</div>
          <div class="tv-value-card__title">{{ block.settings.title }}</div>
          <p class="tv-value-card__body">{{ block.settings.body }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section style="background:var(--tv-sand);padding:100px 40px">
  <div style="max-width:1400px;margin:0 auto">
    <div class="tv-eyebrow">{{ section.settings.story_eyebrow }}</div>
    <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(36px,4vw,54px);font-weight:300;color:var(--tv-espresso);line-height:1.08;margin-bottom:24px">{{ section.settings.story_title }}</h2>
    <p style="font-size:15px;line-height:1.85;color:#6B5B4E;font-weight:300;margin-bottom:18px;max-width:680px">{{ section.settings.story_body1 }}</p>
    {% if section.settings.story_body2 != blank %}
      <p style="font-size:15px;line-height:1.85;color:#6B5B4E;font-weight:300;margin-bottom:18px;max-width:680px">{{ section.settings.story_body2 }}</p>
    {% endif %}
    {% if section.settings.signature != blank %}
      <div style="font-family:'Cormorant Garamond',serif;font-size:32px;font-style:italic;color:var(--tv-mocha);margin-top:32px">{{ section.settings.signature }}</div>
      <div style="font-size:12px;color:var(--tv-taupe);margin-top:4px">{{ section.settings.signature_title }}</div>
    {% endif %}
  </div>
</section>

<section style="background:var(--tv-blush);padding:100px 40px;text-align:center">
  <div class="tv-eyebrow">{{ section.settings.cta_eyebrow }}</div>
  <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(40px,5vw,66px);font-weight:300;color:var(--tv-espresso);line-height:1.05;margin-bottom:36px">{{ section.settings.cta_title }}</h2>
  <div style="display:flex;align-items:center;justify-content:center;gap:20px;flex-wrap:wrap">
    <a class="tv-btn-primary" href="{{ section.settings.cta_btn_url }}">{{ section.settings.cta_btn_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "TV About Page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "textarea", "id": "headline", "label": "Headline", "default": "Built for the dog that goes everywhere with you." },
    { "type": "textarea", "id": "hero_body", "label": "Hero body", "default": "Tailvani started with a simple frustration — why was every pet fashion brand either too costumey, too cheap, or too ugly?" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "quote", "label": "Floating quote", "default": "Your dog is your plus-one. They deserve to look the part." },
    { "type": "text", "id": "quote_source", "label": "Quote source", "default": "— Tailvani, Founded 2024" },
    { "type": "text", "id": "mission_eyebrow", "label": "Mission eyebrow", "default": "Our Mission" },
    { "type": "textarea", "id": "mission_quote", "label": "Mission pull quote", "default": "We design for the dog that goes everywhere with you — and for the person who thinks about what they put on their body." },
    { "type": "textarea", "id": "mission_body", "label": "Mission body", "default": "The millennial dog parent has changed everything. Dogs aren't pets anymore — they're family. Tailvani exists because that lifestyle deserves fashion that keeps up." },
    { "type": "text", "id": "values_eyebrow", "label": "Values eyebrow", "default": "What We Stand For" },
    { "type": "text", "id": "values_title", "label": "Values title", "default": "Three things we never compromise on" },
    { "type": "text", "id": "story_eyebrow", "label": "Story eyebrow", "default": "How We Got Here" },
    { "type": "text", "id": "story_title", "label": "Story title", "default": "From frustration to fashion" },
    { "type": "textarea", "id": "story_body1", "label": "Story paragraph 1", "default": "It started at a Sunday farmer's market. I was carrying my coffee, my tote, feeling put-together — and my dog was wearing a plastic raincoat with a cartoon bone on it." },
    { "type": "textarea", "id": "story_body2", "label": "Story paragraph 2", "default": "Tailvani is the answer to that gap. Built with care, priced honestly, designed for the dog parent who cares — but doesn't want to overthink it." },
    { "type": "text", "id": "signature", "label": "Signature", "default": "Tailvani" },
    { "type": "text", "id": "signature_title", "label": "Signature title", "default": "Founded with love, 2024" },
    { "type": "text", "id": "cta_eyebrow", "label": "CTA eyebrow", "default": "Ready to Shop?" },
    { "type": "text", "id": "cta_title", "label": "CTA title", "default": "Find your dog's new favorite look" },
    { "type": "text", "id": "cta_btn_label", "label": "CTA button label", "default": "Shop the Collection" },
    { "type": "url", "id": "cta_btn_url", "label": "CTA button URL" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🎨" },
        { "type": "text", "id": "title", "label": "Title", "default": "Intentional Design" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Every piece is designed with purpose. No unnecessary graphics, no cheap embroidery." }
      ]
    }
  ],
  "presets": [
    {
      "name": "TV About Page",
      "blocks": [
        { "type": "value", "settings": { "icon": "🎨", "title": "Intentional Design", "body": "Every piece is designed with purpose. No unnecessary graphics, no cheap embroidery. Just clean, minimal silhouettes." } },
        { "type": "value", "settings": { "icon": "🐾", "title": "Pet-First Comfort", "body": "Looking good means nothing if your dog is uncomfortable. Every fabric is soft, breathable, and tested for sensitive skin." } },
        { "type": "value", "settings": { "icon": "✨", "title": "Accessible Quality", "body": "Premium doesn't have to mean expensive. We're obsessive about quality at a price point that makes sense." } }
      ]
    }
  ]
}
{% endschema %}
