<section style="max-width:1400px;margin:80px auto;padding:0 40px;">
  <div class="tv-section-header tv-reveal">
    <div>
      <div class="tv-eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="tv-section-title">{{ section.settings.title }}</h2>
    </div>
  </div>
  <div class="tv-collections-grid">
    {% for block in section.blocks %}
      <a class="tv-collection-card" href="{{ block.settings.collection.url | default: '#' }}" style="{% if forloop.first %}height:600px{% else %}height:280px{% endif %}">
        {% if block.settings.image %}
          <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.name }}" loading="lazy" width="900" height="{% if forloop.first %}1125{% else %}350{% endif %}"/>
        {% elsif block.settings.collection.image %}
          <img src="{{ block.settings.collection.image | image_url: width: 900 }}" alt="{{ block.settings.name }}" loading="lazy" width="900" height="{% if forloop.first %}1125{% else %}350{% endif %}"/>
        {% endif %}
        <div class="tv-collection-card__overlay">
          <div class="tv-collection-card__label">{{ block.settings.label }}</div>
          <div class="tv-collection-card__name">{{ block.settings.name }}</div>
          <div class="tv-collection-card__cta">Shop Now →</div>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "TV Collections Grid",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse by Category" },
    { "type": "text", "id": "title", "label": "Title", "default": "Shop by style" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Override image (optional)" },
        { "type": "text", "id": "label", "label": "Label", "default": "Featured" },
        { "type": "text", "id": "name", "label": "Name", "default": "Apparel & Tops" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TV Collections Grid",
      "blocks": [
        { "type": "collection_card", "settings": { "label": "Featured", "name": "Apparel & Tops" } },
        { "type": "collection_card", "settings": { "label": "Accessories", "name": "Bowties & Collars" } },
        { "type": "collection_card", "settings": { "label": "Just Dropped", "name": "New Arrivals" } }
      ]
    }
  ]
}
{% endschema %}
