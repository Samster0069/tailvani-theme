<section class="tv-email">
  <div class="tv-email__inner tv-reveal">
    <div class="tv-eyebrow">{{ section.settings.eyebrow }}</div>
    <h2 class="tv-email__title">{{ section.settings.title }}</h2>
    <p class="tv-email__sub">{{ section.settings.subtext }}</p>
    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter"/>
      <div class="tv-email__form">
        <input class="tv-email__input" type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required aria-label="Email address"/>
        <button class="tv-email__btn" type="submit">{{ section.settings.btn_label }}</button>
      </div>
    {% endform %}
    <p class="tv-email__note">{{ section.settings.note }}</p>
  </div>
</section>

{% schema %}
{
  "name": "TV Email Signup",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the Pack" },
    { "type": "text", "id": "title", "label": "Title", "default": "Be first to new drops" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "New arrivals, exclusive offers, and styling inspo — straight to your inbox. No fluff, promise." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "note", "label": "Fine print", "default": "By subscribing you agree to our Privacy Policy. Unsubscribe anytime." }
  ],
  "presets": [{ "name": "TV Email Signup" }]
}
{% endschema %}
