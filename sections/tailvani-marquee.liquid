<div class="tv-marquee">
  <div class="tv-marquee__track">
    {% for i in (1..2) %}
      {% for block in section.blocks %}
        <span class="tv-marquee__item">
          {{ block.settings.text }}
          <span class="tv-marquee__dot"></span>
        </span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "TV Marquee Strip",
  "blocks": [
    {
      "type": "item",
      "name": "Marquee Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Soft. Stylish. For Every Walk" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TV Marquee Strip",
      "blocks": [
        { "type": "item", "settings": { "text": "Soft. Stylish. For Every Walk" } },
        { "type": "item", "settings": { "text": "A Style For Every Tail" } },
        { "type": "item", "settings": { "text": "Made for the Millennial Dog Parent" } },
        { "type": "item", "settings": { "text": "Dressed to Impress, Allways" } },
        { "type": "item", "settings": { "text": "Free US Shipping Over $50" } }
      ]
    }
  ]
}
{% endschema %}
