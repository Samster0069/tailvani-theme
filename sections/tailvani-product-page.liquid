{% comment %}
  tailvani-product-page.liquid
  WHERE: Sections/ → Add new section → name: tailvani-product-page

  HOW TO USE:
  Option A (Recommended - easiest):
    1. Go to Templates/ → product.json
    2. Add this section to the sections array alongside main-product

  Option B (Full replacement):
    1. Go to Templates/ → product.json
    2. Replace the "main-product" section entry with "tailvani-product-page"

  This section renders the full product page layout including:
  - Breadcrumb
  - Gallery with thumbnails
  - Title, price, variants
  - ATC + Buy Now buttons
  - Trust signals
  - Accordion (details, specs, shipping, care)
  - Size guide modal
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign is_on_sale = false -%}
{%- if current_variant.compare_at_price > current_variant.price -%}
  {%- assign is_on_sale = true -%}
{%- endif -%}

<!-- BREADCRUMB -->
<nav class="tv-pdp__breadcrumb" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span aria-hidden="true">/</span>
  {%- if collection -%}
    <a href="{{ collection.url }}">{{ collection.title }}</a>
    <span aria-hidden="true">/</span>
  {%- else -%}
    <a href="/collections/all">Shop</a>
    <span aria-hidden="true">/</span>
  {%- endif -%}
  <span>{{ product.title }}</span>
</nav>

<div class="tv-pdp">
  <div class="tv-pdp__layout">

    <!-- ── GALLERY ─────────────────────────────────────── -->
    <div class="tv-pdp__gallery">
      <div class="tv-pdp__main-img">
        {%- if is_on_sale -%}
          <span class="tv-pdp__sale-tag">
            Sale —
            {%- assign savings = current_variant.compare_at_price | minus: current_variant.price -%}
            {%- assign pct = savings | times: 100 | divided_by: current_variant.compare_at_price -%}
            {{ pct }}% Off
          </span>
        {%- endif -%}
        <img
          id="tv-main-img"
          src="{{ product.featured_image | image_url: width: 900 }}"
          alt="{{ product.featured_image.alt | default: product.title }}"
          loading="eager"
          width="900"
        />
      </div>

      {% if product.images.size > 1 %}
        <div class="tv-pdp__thumbs">
          {% for image in product.images limit: 5 %}
            <div
              class="tv-pdp__thumb{% if forloop.first %} is-active{% endif %}"
              data-src="{{ image | image_url: width: 900 }}"
              role="button"
              tabindex="0"
              aria-label="View image {{ forloop.index }}"
            >
              <img
                src="{{ image | image_url: width: 200 }}"
                alt="{{ image.alt | default: product.title }}"
                loading="lazy"
                width="200"
              />
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- ── PRODUCT INFO ────────────────────────────────── -->
    <div class="tv-pdp__info">
      <div class="tv-pdp__brand">{{ product.vendor | default: 'Tailvani' }}</div>
      <h1 class="tv-pdp__title">{{ product.title }}</h1>

      <!-- RATING placeholder (Judge.me replaces this automatically) -->
      <div class="tv-pdp__rating">
        <span class="tv-pdp__stars">★★★★★</span>
        <span class="tv-pdp__rating-count">4.9</span>
        <a class="tv-pdp__rating-link" href="#reviews">See reviews</a>
      </div>

      <!-- PRICE -->
      <div class="tv-pdp__price-block" id="tv-price-block">
        {%- if is_on_sale -%}
          <span class="tv-pdp__price-sale">{{ current_variant.price | money }}</span>
          <span class="tv-pdp__price-orig">{{ current_variant.compare_at_price | money }}</span>
          {%- assign savings = current_variant.compare_at_price | minus: current_variant.price -%}
          <span class="tv-pdp__price-save">Save {{ savings | money }}</span>
        {%- else -%}
          <span class="tv-pdp__price-regular">{{ current_variant.price | money }}</span>
        {%- endif -%}
      </div>

      <!-- FORM -->
      {%- form 'product', product, id: 'tv-product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" id="tv-variant-id"/>

        <!-- COLOR OPTION -->
        {%- assign color_option = product.options_by_name['Color'] -%}
        {%- if color_option -%}
          <div class="tv-pdp__variant-section">
            <div class="tv-pdp__variant-label">
              Color
              <span class="tv-pdp__variant-selected" id="tv-selected-color">
                {{ current_variant.option1 }}
              </span>
            </div>
            <div class="tv-pdp__color-swatches">
              {%- for variant in product.variants -%}
                {%- unless forloop.index > 1 and product.variants[forloop.index0 | minus: 1].option1 == variant.option1 -%}
                  {%- assign swatch_class = variant.option1 | downcase | replace: ' ', '-' -%}
                  <button
                    type="button"
                    class="tv-pdp__color-swatch tv-swatch--{{ swatch_class }}{% if variant.option1 == current_variant.option1 %} is-active{% endif %}"
                    title="{{ variant.option1 }}"
                    data-value="{{ variant.option1 }}"
                    aria-label="{{ variant.option1 }}"
                    style="background-color: {% case variant.option1 %}{% when 'Sage Green' %}#9BAF9E{% when 'Blush Pink' %}#E8C4B8{% when 'Sky Blue' %}#B8C8D8{% when 'White' %}#F5F0E8{% when 'Heather Grey' %}#A8A09A{% when 'Midnight Black' %}#2A2420{% else %}#C4B49A{% endcase %};"
                  ></button>
                {%- endunless -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        <!-- SIZE OPTION -->
        {%- assign size_option_index = nil -%}
        {%- for option in product.options -%}
          {%- if option == 'Size' -%}
            {%- assign size_option_index = forloop.index0 -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if size_option_index != nil -%}
          {%- assign size_option = product.options_with_values[size_option_index] -%}
          <div class="tv-pdp__variant-section">
            <div class="tv-pdp__variant-label">
              Size
              <span class="tv-pdp__variant-selected" id="tv-selected-size">Select a size</span>
            </div>
            <div class="tv-pdp__size-grid">
              {%- for value in size_option.values -%}
                {%- assign variant_for_size = product.variants | where: "option2", value | first -%}
                {%- if variant_for_size == nil -%}
                  {%- assign variant_for_size = product.variants | where: "option1", value | first -%}
                {%- endif -%}
                <button
                  type="button"
                  class="tv-pdp__size-btn{% unless variant_for_size.available %} is-soldout{% endunless %}{% if value == current_variant.option2 or value == current_variant.option1 %} is-active{% endif %}"
                  data-size="{{ value }}"
                  data-variant-id="{{ variant_for_size.id }}"
                  {% unless variant_for_size.available %}disabled aria-disabled="true"{% endunless %}
                >{{ value }}</button>
              {%- endfor -%}
            </div>
            <button type="button" class="tv-pdp__size-guide-link">📏 View Size Guide</button>
          </div>
        {%- endif -%}

        <!-- ADD TO CART -->
        <div class="tv-pdp__atc-row">
          <button
            type="submit"
            name="add"
            id="tv-atc-btn"
            class="tv-pdp__atc"
            {% unless product.available %}disabled{% endunless %}
          >
            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="1.5">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            {%- if product.available -%}
              Add to Cart
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>

          <button type="button" class="tv-pdp__wishlist" aria-label="Save to wishlist">
            <svg viewBox="0 0 24 24">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </button>
        </div>

        <!-- BUY NOW -->
        {{- form | payment_button -}}

      {%- endform -%}

      <!-- TRUST -->
      <div class="tv-pdp__trust">
        <div class="tv-pdp__trust-item">
          <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Free US shipping $50+
        </div>
        <div class="tv-pdp__trust-item">
          <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          30-day returns
        </div>
        <div class="tv-pdp__trust-item">
          <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Pet-safe fabrics
        </div>
      </div>

      <!-- ACCORDION -->
      <div class="tv-accordion">
        <!-- Product Details -->
        <div class="tv-accordion__item">
          <button class="tv-accordion__btn" type="button">
            Product Details
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <div class="tv-accordion__body">
            <div class="tv-accordion__content">
              {{ product.description }}
            </div>
          </div>
        </div>

        <!-- Specifications -->
        <div class="tv-accordion__item">
          <button class="tv-accordion__btn" type="button">
            Specifications
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <div class="tv-accordion__body">
            <div class="tv-accordion__content">
              <div class="tv-spec-grid">
                {%- for tag in product.tags -%}
                  {%- if tag contains 'spec:' -%}
                    {%- assign spec_parts = tag | remove: 'spec:' | split: '|' -%}
                    <div class="tv-spec-item">
                      <div class="tv-spec-key">{{ spec_parts[0] }}</div>
                      <div class="tv-spec-val">{{ spec_parts[1] }}</div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
                {%- comment -%}
                  Add product tags like: spec:Material|Soft ribbed polyester blend
                  to auto-populate specs. Or use metafields.
                {%- endcomment -%}
                <div class="tv-spec-item"><div class="tv-spec-key">Suitable For</div><div class="tv-spec-val">Small to medium dogs</div></div>
                <div class="tv-spec-item"><div class="tv-spec-key">Season</div><div class="tv-spec-val">All-season wear</div></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Shipping -->
        <div class="tv-accordion__item">
          <button class="tv-accordion__btn" type="button">
            Shipping & Returns
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <div class="tv-accordion__body">
            <div class="tv-accordion__content">
              <ul>
                <li>Free standard shipping on US orders over $50</li>
                <li>Standard shipping: 5–8 business days</li>
                <li>Expedited shipping: 2–3 business days</li>
                <li>Free returns & exchanges within 30 days</li>
                <li>Items must be unworn and in original condition</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Care -->
        <div class="tv-accordion__item">
          <button class="tv-accordion__btn" type="button">
            Care Instructions
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <div class="tv-accordion__body">
            <div class="tv-accordion__content">
              <ul>
                <li>Machine wash cold on gentle cycle</li>
                <li>Use mild, pet-safe detergent</li>
                <li>Lay flat to dry — do not tumble dry</li>
                <li>Do not iron directly on fabric</li>
                <li>Do not bleach</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /tv-pdp__info -->
  </div><!-- /tv-pdp__layout -->
</div><!-- /tv-pdp -->

<!-- SIZE MODAL -->
<div class="tv-modal-overlay" id="tv-size-overlay"></div>
<div class="tv-modal" id="tv-size-modal" role="dialog" aria-label="Size Guide">
  <button class="tv-modal__close" type="button">
    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <div class="tv-modal__title">Size Guide</div>
  <p class="tv-modal__sub">Measure your dog's neck circumference and back length (base of neck to base of tail). When between sizes, size up for comfort.</p>
  <table class="tv-size__table">
    <thead>
      <tr><th>Size</th><th>Neck (in)</th><th>Chest (in)</th><th>Back Length (in)</th></tr>
    </thead>
    <tbody>
      <tr><td><strong>XS</strong></td><td>7–9"</td><td>10–12"</td><td>7–8"</td></tr>
      <tr><td><strong>S</strong></td><td>9–11"</td><td>12–14"</td><td>9–11"</td></tr>
      <tr><td><strong>M</strong></td><td>11–14"</td><td>14–17"</td><td>11–14"</td></tr>
      <tr><td><strong>L</strong></td><td>14–17"</td><td>17–21"</td><td>14–17"</td></tr>
      <tr><td><strong>XL</strong></td><td>17–20"</td><td>21–25"</td><td>17–20"</td></tr>
    </tbody>
  </table>
</div>

<!-- SIZE + VARIANT JS (inline for product page) -->
<script>
(function(){
  // Size button → update hidden variant ID
  const sizeBtns = document.querySelectorAll('.tv-pdp__size-btn:not(.is-soldout)');
  const variantInput = document.getElementById('tv-variant-id');
  const selectedSizeEl = document.getElementById('tv-selected-size');

  sizeBtns.forEach(btn => {
    btn.addEventListener('click', function(){
      sizeBtns.forEach(b => b.classList.remove('is-active'));
      this.classList.add('is-active');
      if(selectedSizeEl) selectedSizeEl.textContent = this.dataset.size;
      if(variantInput && this.dataset.variantId){
        variantInput.value = this.dataset.variantId;
      }
    });
  });

  // Color button → update selected color label
  const colorBtns = document.querySelectorAll('.tv-pdp__color-swatch');
  const selectedColorEl = document.getElementById('tv-selected-color');
  colorBtns.forEach(btn => {
    btn.addEventListener('click', function(){
      colorBtns.forEach(b => b.classList.remove('is-active'));
      this.classList.add('is-active');
      if(selectedColorEl) selectedColorEl.textContent = this.title;
    });
  });
})();
</script>

{% schema %}
{
  "name": "TV Product Page",
  "settings": [],
  "presets": [{ "name": "TV Product Page" }]
}
{% endschema %}
