<section class="tv-reviews">
  <div class="tv-section-header tv-reveal">
    <div>
      <div class="tv-eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="tv-section-title">{{ section.settings.title }}</h2>
    </div>
  </div>
  <div class="tv-reviews__grid">
    {% for block in section.blocks %}
      <div class="tv-review-card tv-reveal">
        <div class="tv-review-card__quote">"</div>
        <div class="tv-review-card__stars">★★★★★</div>
        <p class="tv-review-card__text">{{ block.settings.review }}</p>
        <div class="tv-review-card__author">
          <div class="tv-review-card__avatar">{{ block.settings.emoji }}</div>
          <div>
            <div class="tv-review-card__name">{{ block.settings.name }}</div>
            <div class="tv-review-card__pet">{{ block.settings.pet }}</div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "TV Reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Customer Love" },
    { "type": "text", "id": "title", "label": "Title", "default": "What dog parents say" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "review", "label": "Review text", "default": "The quality is incredible and my dog gets compliments everywhere we go." },
        { "type": "text", "id": "name", "label": "Reviewer name", "default": "Sarah M." },
        { "type": "text", "id": "pet", "label": "Pet description", "default": "Dog mom to Biscuit, Golden Retriever" },
        { "type": "text", "id": "emoji", "label": "Avatar emoji", "default": "🐕" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TV Reviews",
      "blocks": [
        { "type": "review", "settings": { "review": "The Classic Bowtie is the most complimented thing my dog has ever worn. Stopped three times on our morning walk.", "name": "Sarah M.", "pet": "Dog mom to Biscuit, Golden Retriever", "emoji": "🐕" } },
        { "type": "review", "settings": { "review": "Finally a pet brand that gets it. The aesthetic is everything I wanted — minimal, stylish, not cutesy.", "name": "Jordan K.", "pet": "Dog mom to Luna, French Bulldog", "emoji": "🐾" } },
        { "type": "review", "settings": { "review": "Ordered the Ribbed Collar Vest and it arrived so fast. Quality is honestly better than I expected.", "name": "Alex T.", "pet": "Dog dad to Mochi, Shih Tzu", "emoji": "🦮" } }
      ]
    }
  ]
}
{% endschema %}
