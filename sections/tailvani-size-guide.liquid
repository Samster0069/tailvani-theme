<section class="tv-size" id="size-guide">
  <div class="tv-size__inner">
    <div class="tv-reveal">
      <h2 class="tv-size__title">{{ section.settings.title }}</h2>
      <p class="tv-size__desc">{{ section.settings.desc }}</p>
      <div class="tv-size__badges">
        <span class="tv-size__badge">🐕 Small Dogs</span>
        <span class="tv-size__badge">🐕‍🦺 Medium Dogs</span>
        <span class="tv-size__badge">Adjustable Collar</span>
      </div>
    </div>
    <div class="tv-reveal">
      <table class="tv-size__table">
        <thead><tr><th>Size</th><th>Neck (in)</th><th>Chest (in)</th><th>Back Length (in)</th></tr></thead>
        <tbody>
          <tr><td><strong>XS</strong></td><td>7–9"</td><td>10–12"</td><td>7–8"</td></tr>
          <tr><td><strong>S</strong></td><td>9–11"</td><td>12–14"</td><td>9–11"</td></tr>
          <tr><td><strong>M</strong></td><td>11–14"</td><td>14–17"</td><td>11–14"</td></tr>
          <tr><td><strong>L</strong></td><td>14–17"</td><td>17–21"</td><td>14–17"</td></tr>
          <tr><td><strong>XL</strong></td><td>17–20"</td><td>21–25"</td><td>17–20"</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "TV Size Guide",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Find the perfect fit" },
    { "type": "textarea", "id": "desc", "label": "Description", "default": "Measure your dog's neck circumference and back length to find their size. When between sizes, size up for comfort." }
  ],
  "presets": [{ "name": "TV Size Guide" }]
}
{% endschema %}
