<section class="tv-contact">
  <div>
    <div class="tv-eyebrow">{{ section.settings.eyebrow }}</div>
    <h1 class="tv-contact__title">{{ section.settings.title }}</h1>
    <p class="tv-contact__body">{{ section.settings.body }}</p>
    <div class="tv-contact__methods">
      {% if section.settings.email != blank %}
        <div class="tv-contact__method">
          <div class="tv-contact__method-icon">
            <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <div class="tv-contact__method-title">Email Us</div>
            <div class="tv-contact__method-value">{{ section.settings.email }}</div>
            <div class="tv-contact__method-note">Response within 24–48 hours</div>
          </div>
        </div>
      {% endif %}
      <div class="tv-contact__method">
        <div class="tv-contact__method-icon">
          <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        </div>
        <div>
          <div class="tv-contact__method-title">Returns & Orders</div>
          <div class="tv-contact__method-value">Free 30-day returns</div>
          <div class="tv-contact__method-note">No questions asked.</div>
        </div>
      </div>
    </div>
  </div>

  <div class="tv-contact-form">
    <div class="tv-contact-form__title">Send a Message</div>
    <p class="tv-contact-form__sub">We read every single one. Promise. 🐾</p>
    {% form 'contact', id: 'tv-contact-form' %}
      {% if form.posted_successfully? %}
        <div style="text-align:center;padding:32px 0">
          <div style="font-size:44px;margin-bottom:14px">🐾</div>
          <div style="font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:300;color:var(--tv-espresso);margin-bottom:8px">Message Received!</div>
          <p style="font-size:14px;color:var(--tv-mocha)">We'll be back with you within 24–48 hours.</p>
        </div>
      {% else %}
        {% if form.errors %}
          <div style="background:rgba(196,82,58,.1);border:1px solid var(--tv-accent);border-radius:2px;padding:16px;margin-bottom:20px;font-size:13px;color:var(--tv-accent)">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}
        <div class="tv-form-row">
          <div class="tv-form-group">
            <label class="tv-form-label" for="contact-first">First Name</label>
            <input class="tv-form-input" id="contact-first" type="text" name="contact[first_name]" placeholder="Your first name"/>
          </div>
          <div class="tv-form-group">
            <label class="tv-form-label" for="contact-last">Last Name</label>
            <input class="tv-form-input" id="contact-last" type="text" name="contact[last_name]" placeholder="Your last name"/>
          </div>
        </div>
        <div class="tv-form-group">
          <label class="tv-form-label" for="contact-email">Email *</label>
          <input class="tv-form-input" id="contact-email" type="email" name="contact[email]" value="{{ form.email }}" placeholder="your@email.com" required/>
        </div>
        <div class="tv-form-group">
          <label class="tv-form-label" for="contact-subject">Subject</label>
          <select class="tv-form-select" id="contact-subject" name="contact[subject]">
            <option value="">Select a topic</option>
            <option>Order Question</option>
            <option>Sizing Help</option>
            <option>Returns & Exchanges</option>
            <option>Press / Collaboration</option>
            <option>Just Saying Hi 🐾</option>
            <option>Other</option>
          </select>
        </div>
        <div class="tv-form-group">
          <label class="tv-form-label" for="contact-dog">Your Dog's Name (optional)</label>
          <input class="tv-form-input" id="contact-dog" type="text" name="contact[dog_name]" placeholder="e.g. Mochi, Biscuit, Luna..."/>
        </div>
        <div class="tv-form-group">
          <label class="tv-form-label" for="contact-body">Message *</label>
          <textarea class="tv-form-textarea" id="contact-body" name="contact[body]" placeholder="Tell us everything..." required>{{ form.body }}</textarea>
        </div>
        <button type="submit" class="tv-form-submit">Send Message</button>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "TV Contact Page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Get in Touch" },
    { "type": "text", "id": "title", "label": "Title", "default": "We'd love to hear from you" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Questions about sizing, an order, or just want to share a photo of your dog? We read every message." },
    { "type": "text", "id": "email", "label": "Email address", "default": "hello@shoptailvani.com" }
  ],
  "presets": [{ "name": "TV Contact Page" }]
}
{% endschema %}
