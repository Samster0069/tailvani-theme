<style>
  .tv-nav-wrapper{position:sticky;top:0;z-index:100;background:rgba(253,250,245,.94);backdrop-filter:blur(16px);border-bottom:1px solid rgba(196,180,154,.25);transition:box-shadow .3s}
  .tv-nav-wrapper.tv-scrolled{box-shadow:0 4px 32px rgba(61,43,31,.08)}
  .tv-nav{max-width:1400px;margin:0 auto;height:72px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 40px;gap:20px}
  .tv-nav-left{display:flex;align-items:center;gap:28px}
  .tv-nav-link{font-size:12px;letter-spacing:.1em;text-transform:uppercase;font-weight:500;color:#3D2B1F;position:relative;padding-bottom:2px;text-decoration:none;transition:color .2s}
  .tv-nav-link::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:#8C6E52;transition:width .3s}
  .tv-nav-link:hover::after{width:100%}
  .tv-nav-link:hover{color:#8C6E52}
  .tv-nav-logo a{font-family:'Cormorant Garamond',Georgia,serif;font-size:28px;font-weight:300;letter-spacing:.08em;color:#3D2B1F;font-style:italic;text-decoration:none}
  .tv-nav-right{display:flex;align-items:center;justify-content:flex-end;gap:16px}
  .tv-nav-icon{width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:50%;transition:background .2s;color:#3D2B1F;text-decoration:none;background:none;border:none;cursor:pointer}
  .tv-nav-icon:hover{background:#E8DFD0}
  .tv-nav-icon svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.5}
  @media(max-width:900px){.tv-nav{padding:0 20px}.tv-nav-left .tv-nav-link:not(:first-child){display:none}}
</style>

<div class="tv-nav-wrapper" id="tv-nav-wrapper">
  <nav class="tv-nav" role="navigation" aria-label="Main navigation">
    <div class="tv-nav-left">
      {% for link in section.settings.menu.links %}
        <a class="tv-nav-link" href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </div>

    <div class="tv-nav-logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">{{ shop.name }}</a>
    </div>

    <div class="tv-nav-right">
      <a class="tv-nav-icon" href="{{ routes.search_url }}" aria-label="Search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </a>
      <a class="tv-nav-icon" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a class="tv-nav-icon" href="{{ routes.cart_url }}" aria-label="Cart ({{ cart.item_count }} items)" style="position:relative">
        <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        {% if cart.item_count > 0 %}
          <span style="position:absolute;top:2px;right:2px;width:16px;height:16px;background:#C4523A;color:white;border-radius:50%;font-size:9px;font-weight:600;display:flex;align-items:center;justify-content:center">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </nav>
</div>

{% schema %}
{
  "name": "TV Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" }
  ],
  "presets": [{ "name": "TV Header" }]
}
{% endschema %}
