<div class="tv-trust">
  <div class="tv-trust__inner">
    {% for block in section.blocks %}
      <div class="tv-trust__item tv-reveal">
        <div class="tv-trust__icon">
          <svg viewBox="0 0 24 24">
            {% case block.settings.icon %}
              {% when 'shipping' %}<rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              {% when 'returns' %}<polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
              {% when 'shield' %}<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              {% when 'heart' %}<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              {% else %}<circle cx="12" cy="12" r="10"/>
            {% endcase %}
          </svg>
        </div>
        <div>
          <div class="tv-trust__title">{{ block.settings.title }}</div>
          <div class="tv-trust__desc">{{ block.settings.desc }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "TV Trust Bar",
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "shipping", "label": "Shipping" }, { "value": "returns", "label": "Returns" }, { "value": "shield", "label": "Shield" }, { "value": "heart", "label": "Heart" }], "default": "shipping" },
        { "type": "text", "id": "title", "label": "Title", "default": "Free US Shipping" },
        { "type": "text", "id": "desc", "label": "Description", "default": "On all orders over $50." }
      ]
    }
  ],
  "presets": [
    {
      "name": "TV Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "shipping", "title": "Free US Shipping", "desc": "On all orders over $50. No code needed." } },
        { "type": "trust_item", "settings": { "icon": "returns", "title": "Easy Returns", "desc": "30-day hassle-free returns. No questions." } },
        { "type": "trust_item", "settings": { "icon": "shield", "title": "Pet-Safe Materials", "desc": "Soft, tested fabrics. Safe for sensitive skin." } },
        { "type": "trust_item", "settings": { "icon": "heart", "title": "Made with Love", "desc": "Every piece designed for real dog parents." } }
      ]
    }
  ]
}
{% endschema %}
